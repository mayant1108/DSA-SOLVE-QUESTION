
#include <iostream>
using namespace std;

int main()
{
    int x;
    cin >> x;

    if (x >= 18)
    {
        cout << "eligible to vote" << endl;
        if (x >= 60)
        {
            cout << "eligible to vote and senior citizen" << endl;
        }
    }
    else
    {
        cout << "not eligible to vote" << endl;
    }

    return 0;
}
