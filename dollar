#include <iostream>
using namespace std;

int main() {
    int t;
    cin >> t;

    while(t--) {
        int A, B;
        cin >> A >> B;

        int first = A * 10;
        int second = B * 5;

        if(first > second) {
            cout << "FIRST" << endl;
        }
        else if(second > first) {
            cout << "SECOND" << endl;
        }
        else {
            cout << "ANY" << endl;
        }
    }

    return 0;
}
