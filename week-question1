
#include <iostream>
using namespace std;
    
int main() {
    int day;
    cin >> day;

    switch (day) {
    case 1:
        cout << "Monday" << endl;
        break;
    
    case 2:
        cout << "Tuesday" << endl;
        break;

    case 3:
        cout << "wednesday" << endl;
        break; 
        
    case 4:
        cout << "thrusday" << endl;
        break;
        
    case 6:
        cout << "saturday" << endl;
        break; 
        
    case 7:
        cout << "sunday" << endl;
        break;    
    
    default:
           cout <<"no day" << endl;
        break;
    }

}
