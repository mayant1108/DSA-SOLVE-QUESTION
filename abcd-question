#include <iostream>
using namespace std;

int main() {

    string txt = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";

    // Using length()
    cout << "The length of the text string is: " 
         << txt.length() << endl;

    // Using size()
    cout << "The length of the text string is: " 
         << txt.size();

    return 0;
}
