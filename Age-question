
#include <iostream>
using namespace std;

int main() {
    int age;
    char citizen;

    cout << "Enter your age: ";
    cin >> age;
    cout << "Are you an Indian citizen? (y/n): ";
    cin >> citizen;

    if (age >= 18) {
        if (citizen == 'y' ) { 
            cout << "You are eligible to vote in India.";
        } else {
            cout << "You are not eligible because you are not an Indian citizen.";
        }
    } else {
        cout << "You are not eligible because you are under 18.";
    }

    return 0;
}
